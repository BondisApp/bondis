# ── API GCBA ──────────────────────────────
GCBA_CLIENT_ID=tu_client_id_aqui
GCBA_CLIENT_SECRET=tu_client_secret_aqui

# ── SERVIDOR ──────────────────────────────
PORT=3000
NODE_ENV=development

# ── INTERVALOS ────────────────────────────
GCBA_POLL_INTERVAL=30000   # 30 segundos (igual que la API)
GPS_TIMEOUT=120000          # 2 minutos sin señal = offline

# ── CORS (dominios permitidos) ────────────
ALLOWED_ORIGINS=http://localhost:5500,https://bondis.com.ar
